{
  "manifest_version": 3,
  "name": "YTMusic API",
  "version": "1.0.0",
  "description": "YouTube Music üzerinden anlık metadata ve dinleme istatistikleri sunan API servisi.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://music.youtube.com/*",
    "https://api.music.baransel.site/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Music Metadata API"
  },
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}

